<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>items</key>
	<array>

		<!-- ── Enable ── -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>PHEnableLabel</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>cellClass</key>
			<string>MTTintedSwitchCell</string>
			<key>default</key>
			<true/>
			<key>defaults</key>
			<string>com.macthemes.phantomprefs</string>
			<key>key</key>
			<string>enabled</string>
			<key>label</key>
			<string>PHEnableSwitch</string>
		</dict>

		<!-- ── Version Spoof ── -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>PHVersionLabel</string>
			<key>footerText</key>
			<string>PHVersionFooter</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSEditTextCell</string>
			<key>default</key>
			<string>25.1.83.0</string>
			<key>defaults</key>
			<string>com.macthemes.phantomprefs</string>
			<key>key</key>
			<string>newVersion</string>
			<key>label</key>
			<string>PHVersionFieldLabel</string>
			<key>noAutoCorrect</key>
			<true/>
			<key>placeholder</key>
			<string>e.g. 25.1.83.0</string>
		</dict>

		<!-- ── Fixes ── -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>PHFixesLabel</string>
			<key>footerText</key>
			<string>PHFixesFooter</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>cellClass</key>
			<string>MTTintedSwitchCell</string>
			<key>default</key>
			<false/>
			<key>defaults</key>
			<string>com.macthemes.phantomprefs</string>
			<key>key</key>
			<string>fixNotifications</string>
			<key>label</key>
			<string>PHFixNotifSwitch</string>
		</dict>

		<!-- ── Contact ── -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>PHContactLabel</string>
		</dict>
		<dict>
			<key>action</key>
			<string>open:</string>
			<key>cell</key>
			<string>PSButtonCell</string>
			<key>cellClass</key>
			<string>MTContactCell</string>
			<key>height</key>
			<real>60</real>
			<key>image</key>
			<string>telegram.png</string>
			<key>subTitle</key>
			<string>PHChannelSubtitle</string>
			<key>title</key>
			<string>PHChannelTitle</string>
			<key>url</key>
			<string>https://t.me/spottsee</string>
		</dict>
		<dict>
			<key>action</key>
			<string>open:</string>
			<key>cell</key>
			<string>PSButtonCell</string>
			<key>cellClass</key>
			<string>MTContactCell</string>
			<key>height</key>
			<real>60</real>
			<key>image</key>
			<string>telegram.png</string>
			<key>subTitle</key>
			<string>PHDeveloperSubtitle</string>
			<key>title</key>
			<string>PHDeveloperTitle</string>
			<key>url</key>
			<string>https://t.me/ispott</string>
		</dict>

		<!-- ── Footer ── -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>footerAlignment</key>
			<integer>1</integer>
			<key>footerText</key>
			<string>Phantom for WhatsApp · by espotty</string>
		</dict>

	</array>
	<key>title</key>
	<string></string>
</dict>
</plist>
